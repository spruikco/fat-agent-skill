# FAT Agent — optional environment variables.
# Copy to `.env` and fill in YOUR OWN values. Never commit a real key —
# `.env` is gitignored. These are only needed for optional enrichments;
# the audit runs fully without them.

# SEMrush Analytics API key — enables the optional SEMrush enrichment
# (authority, organic keywords/traffic, trends, top keyword positions).
# Get yours at: Account → Subscription info → API units.
SEMRUSH_API_KEY=

# (Optional) Google PageSpeed Insights API key for higher CWV quota.
# Basic PageSpeed usage works without a key.
PAGESPEED_API_KEY=
